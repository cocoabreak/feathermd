{
  "name": "feathermd",
  "version": "0.1.0",
  "description": "A fast, read-only Markdown viewer for local files.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cocoabreak/feathermd.git"
  },
  "homepage": "https://github.com/cocoabreak/feathermd",
  "bugs": {
    "url": "https://github.com/cocoabreak/feathermd/issues"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:smoke": "node e2e/smoke.mjs",
    "e2e:check-production": "node scripts/check-e2e-production.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "dompurify": "^3.4.12",
    "js-yaml": "^5.2.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "postcss": "^8.5.19",
    "postcss-prefix-selector": "^2.1.1",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/postcss-prefix-selector": "^1.16.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  }
}
